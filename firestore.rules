rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Private user data ─────────────────────────────────────
    // users/{userId}/profile/info
    // users/{userId}/accounts/{accountId}
    // users/{userId}/transactions/{txId}
    // users/{userId}/fixedCosts/{id}
    // users/{userId}/piggyBanks/{id}
    // users/{userId}/goals/{id}
    //
    // Only the owner can ever read or write their own data.
    match /users/{userId} {
      match /{collection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ─── Shared house data ──────────────────────────────────────
    // houses/{houseId}                       -> { members: [uid1, uid2], ... }
    // houses/{houseId}/accounts/{id}
    // houses/{houseId}/transactions/{id}
    // houses/{houseId}/renovations/{id}
    match /houses/{houseId} {

      // Any signed-in user can fetch a house doc by its code (needed to join).
      // The houses collection itself can never be listed/enumerated.
      allow get: if request.auth != null;
      allow list: if false;

      // Creating a house: you can only create yourself as the sole member.
      allow create: if request.auth != null
                    && request.resource.data.members.size() == 1
                    && request.resource.data.members[0] == request.auth.uid;

      // Updating a house: allowed if you're already a member,
      // OR you're joining (adding your own uid to members).
      allow update: if request.auth != null
                    && (
                      request.auth.uid in resource.data.members
                      || request.auth.uid in request.resource.data.members
                    );

      allow delete: if false;

      // Subcollections (accounts, transactions, renovations):
      // only members of this house can read/write.
      match /{collection}/{docId} {
        allow read, write: if request.auth != null
                            && request.auth.uid in
                               get(/databases/$(database)/documents/houses/$(houseId)).data.members;
      }
    }
  }
}
